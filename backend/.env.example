NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/deploywatch?schema=public
REDIS_URL=redis://localhost:6379
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
MONITORING_DISPATCHER_INTERVAL_MS=60000
MONITORING_BATCH_LIMIT=100
HTTP_REQUEST_TIMEOUT_MS=10000
EMAIL_FROM=alerts@deploywatch.local
API_BASE_URL=http://localhost:4000
